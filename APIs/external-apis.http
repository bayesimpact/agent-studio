# curl -H "Authorization: Bearer XXX" -H "Content-Type: application/json" -d '{"input":[{"country":"US","domain":"indeed.com","keyword_search":"analyst","location":"New York, NY","date_posted":"Last 24 hours","posted_by":"","location_radius":""},{"country":"FR","domain":"fr.indeed.com","keyword_search":"product manager","location":"Paris","date_posted":"Last 7 days","posted_by":"","location_radius":""},{"country":"US","domain":"indeed.com","keyword_search":"product manager","location":"New York, NY","date_posted":"","posted_by":"","location_radius":""}]}' "https://api.brightdata.com/datasets/v3/scrape?dataset_id=gd_l4dx9j9sscpvs7no2&notify=false&include_errors=true&type=discover_new&discover_by=keyword"
POST https://api.brightdata.com/datasets/v3/scrape?dataset_id=gd_l4dx9j9sscpvs7no2&notify=false&include_errors=true&
    type=discover_new&discover_by=keyword
Authorization: Bearer {{indeedBearer}}
Content-Type: application/json

{
  "input": [
    {
      "country": "US",
      "domain": "indeed.com",
      "keyword_search": "welder",
      "location": "Columbus, OH",
      "date_posted": "Last 3 days",
      "posted_by": "",
      "location_radius": "Within 5 miles"
    }
  ]
}



