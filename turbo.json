{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "POSTHOG_KEY",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST",
    "VITE_PUBLIC_POSTHOG_KEY",
    "VITE_PUBLIC_POSTHOG_HOST",
    "VITE_POSTHOG_KEY",
    "VITE_POSTHOG_HOST"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "typecheck": {},
    "lint": {},
    "test": {
      "env": ["DATABASE_URL"]
    },
    "test:e2e": {}
  }
}
