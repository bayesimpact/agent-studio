{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "typecheck": {},
    "lint": {},
    "check:boundaries": {
      "inputs": [
        "src/**",
        "tsconfig.json",
        ".dependency-cruiser.cjs",
        ".dependency-cruiser-known-violations.json",
        ".madgerc",
        "baselines/madge-circular.json",
        "scripts/check-circular.mjs",
        "package.json"
      ]
    },
    "test": {
      "env": ["DATABASE_URL"]
    },
    "test:e2e": {}
  }
}
